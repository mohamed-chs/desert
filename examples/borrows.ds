def increment(val: i32) -> i32:
    return val + 1

def display(val: &i32):
    $print("The value is: {val}")

def main():
    mut count = 10

    # Pure value update
    count = increment(count)

    # Passing a shared reference (immutable borrow)
    display(&count)

    # Moving ownership
    let new_count = move count
    $print("Count has been moved to new_count: {new_count}")
